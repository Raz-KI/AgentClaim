# API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://agentclaim:agentclaim@localhost:5432/agentclaim

# AI providers (set one or both)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4.1
VISION_MODEL=gpt-4.1
EMBEDDING_MODEL=

# OCR
TESSERACT_CMD=
OCR_PRIMARY=vision
OCR_FALLBACK=tesseract

# Observability
LOG_LEVEL=INFO
TRACE_PERSIST=true

# Policy
POLICY_TERMS_PATH=backend/app/policy/policy_terms.json

# Confidence thresholds
CONFIDENCE_MANUAL_REVIEW_THRESHOLD=0.65
CONFIDENCE_AUTO_APPROVE_THRESHOLD=0.85
